---
import { metrics } from '~/data/metrics';
import { getLang, t } from '~/i18n';

const lang = getLang(Astro.url.pathname);
const tr = t(lang);

const fellowshipName = lang === 'zh'
  ? 'Cancer Institute NSW Early Career Fellowship'
  : metrics.fellowship.name;
const peerReviewedCaption = lang === 'zh'
  ? `${metrics.firstOrCoFirstAuthor} ${tr.spotlight.firstCoFirst} · ${metrics.totalFunding} ${tr.spotlight.funding}`
  : `${metrics.firstOrCoFirstAuthor} ${tr.spotlight.firstCoFirst} · ${metrics.totalFunding} ${tr.spotlight.funding}`;

const items = [
  {
    label: `${tr.spotlight.awarded} ${metrics.fellowship.awardedYear}`,
    value: metrics.fellowship.amount,
    unit: metrics.fellowship.years,
    caption: fellowshipName,
  },
  {
    label: tr.spotlight.scholar,
    value: metrics.totalCitations.toLocaleString(),
    unit: tr.spotlight.citations,
    caption: `${tr.spotlight.hIndex} ${metrics.hIndex} · ${tr.spotlight.i10} ${metrics.i10Index}`,
  },
  {
    label: tr.spotlight.peerReviewed,
    value: `${metrics.peerReviewedPapers}`,
    unit: tr.spotlight.publications,
    caption: peerReviewedCaption,
  },
];
---

<section aria-label="Spotlight" class="border-b border-border bg-surface-2/40">
  <div class="container-page grid gap-0 md:grid-cols-3">
    {
      items.map((it, i) => (
        <div
          class:list={[
            'px-0 py-8 md:px-8',
            i > 0 && 'border-t border-border md:border-l md:border-t-0',
          ]}
        >
          <div class="section-label mb-3">{it.label}</div>
          <div class="flex items-baseline gap-2">
            <span class="font-display text-3xl font-semibold text-fg md:text-4xl">{it.value}</span>
            <span class="text-sm text-muted">{it.unit}</span>
          </div>
          <p class="mt-2 text-sm text-muted">{it.caption}</p>
        </div>
      ))
    }
  </div>
</section>
