---
import type { CollectionEntry } from 'astro:content';
import { Icon } from 'astro-icon/components';
import { formatMonthYear } from '~/lib/format';

export interface Props {
  talk: CollectionEntry<'talks'>;
}

const { talk } = Astro.props;
const d = talk.data;

const typeLabel: Record<typeof d.type, string> = {
  invited: 'Invited',
  oral: 'Oral',
  poster: 'Poster',
  seminar: 'Seminar',
  media: 'Media',
};
---

<article class="flex flex-col gap-1 border-b border-border py-5 last:border-b-0 md:flex-row md:items-baseline md:gap-6">
  <div class="flex min-w-[9rem] items-center gap-2 text-sm text-muted md:block">
    <span class="font-mono text-xs uppercase tracking-wide">{formatMonthYear(d.date)}</span>
    <span class="chip-accent ml-2 hidden md:ml-0 md:mt-1 md:inline-flex">{typeLabel[d.type]}</span>
  </div>
  <div class="flex-1">
    <h3 class="font-display text-base font-semibold leading-snug text-fg md:text-lg">
      {d.url ? (
        <a href={d.url} class="link-underline" rel="noopener noreferrer" target="_blank">
          {d.title}
          <Icon name="lucide:arrow-up-right" class="ml-0.5 inline h-3.5 w-3.5 opacity-60" />
        </a>
      ) : (
        d.title
      )}
    </h3>
    <div class="mt-1 text-sm text-muted">
      {d.event}{d.location ? ` · ${d.location}` : ''}
    </div>
    {d.summary && <p class="mt-2 max-w-prose text-sm text-muted">{d.summary}</p>}
    <span class="chip-accent mt-2 md:hidden">{typeLabel[d.type]}</span>
  </div>
</article>
