---
import { Icon } from 'astro-icon/components';
import { site } from '~/data/site';
import { metrics } from '~/data/metrics';

const cta = [
  { href: site.cv.path, label: 'Download CV', icon: 'lucide:download', accent: true, download: true },
  { href: site.socials.email, label: 'Email', icon: 'lucide:mail', accent: false },
  { href: site.socials.scholar, label: 'Google Scholar', icon: 'simple-icons:googlescholar', accent: false, external: true },
];
---

<section class="relative overflow-hidden border-b border-border">
  {/* Soft background accents */}
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 bg-[radial-gradient(60rem_20rem_at_100%_-10%,rgb(var(--accent)/0.08),transparent),radial-gradient(40rem_20rem_at_0%_110%,rgb(var(--accent-2)/0.07),transparent)]"
  >
  </div>

  <div class="container-page relative grid items-center gap-10 py-20 md:grid-cols-12 md:gap-12 md:py-28">
    <div class="md:col-span-8">
      <div class="section-label">Cancer data scientist · Sydney</div>
      <h1 class="h-display mt-2 max-w-[18ch] font-semibold">
        Zhaoxiang <span class="text-accent">Cai</span>.
      </h1>
      <p class="mt-6 max-w-prose text-lg text-muted md:text-xl">
        Senior Data Scientist at <a href={site.affiliations[0].url} class="link-underline text-fg" rel="noopener noreferrer" target="_blank">CMRI</a>
        and Conjoint Associate Lecturer at the <a href={site.affiliations[1].url} class="link-underline text-fg" rel="noopener noreferrer" target="_blank">University of Sydney</a>.
        I build deep-learning methods — federated, generative, and transformer-based — for cancer multi-omics, aimed at
        translation into clinical precision oncology.
      </p>

      <div class="mt-8 flex flex-wrap items-center gap-3">
        {
          cta.map((c) => (
            <a
              href={c.href}
              class:list={[
                'group inline-flex items-center gap-2 rounded-md px-4 py-2.5 text-sm font-medium transition',
                c.accent
                  ? 'bg-accent text-white hover:bg-accent/90'
                  : 'border border-border bg-surface text-fg hover:border-accent hover:text-accent',
              ]}
              rel={c.external ? 'noopener noreferrer' : undefined}
              target={c.external ? '_blank' : undefined}
              download={c.download ? '' : undefined}
            >
              <Icon name={c.icon} class="h-4 w-4" />
              {c.label}
              {c.external && <Icon name="lucide:arrow-up-right" class="h-3.5 w-3.5 opacity-60" />}
            </a>
          ))
        }
      </div>

      <div class="mt-10 flex flex-wrap items-center gap-x-8 gap-y-4 text-sm text-muted">
        {
          site.affiliations.map((a) => (
            <a
              href={a.url}
              class="group flex items-center gap-3 transition hover:text-fg"
              rel="noopener noreferrer"
              target="_blank"
            >
              <img
                src={a.logo}
                alt=""
                loading="lazy"
                class="h-8 w-8 opacity-80 transition group-hover:opacity-100 dark:brightness-0 dark:invert"
              />
              <div class="text-xs leading-tight">
                <div class="font-medium">{a.nameShort}</div>
                <div class="opacity-70">{a.role}</div>
              </div>
            </a>
          ))
        }
      </div>
    </div>

    <div class="md:col-span-4">
      <div class="relative mx-auto aspect-square w-full max-w-[280px]">
        {/* Photo-less fallback: monogram with a radial ring */}
        <div class="absolute inset-0 rounded-full border border-border bg-surface"></div>
        <div
          class="absolute inset-3 rounded-full bg-gradient-to-br from-accent/15 to-accent-2/10"
        >
        </div>
        <div class="absolute inset-0 grid place-items-center">
          <div class="text-center">
            <span class="block font-display text-6xl font-semibold tracking-tight text-accent">{site.initials}</span>
            <span class="mt-2 block font-mono text-[10px] uppercase tracking-[0.16em] text-muted">PhD · Cancer Data Science</span>
          </div>
        </div>
        {/* Badge for fellowship */}
        <div class="absolute -bottom-3 left-1/2 flex -translate-x-1/2 items-center gap-1.5 whitespace-nowrap rounded-full border border-border bg-surface px-3 py-1 text-[11px] font-medium shadow-sm">
          <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
          <span class="text-muted">{metrics.fellowship.awardedYear} CINSW Fellow</span>
        </div>
      </div>
    </div>
  </div>
</section>
