---
import { Icon } from 'astro-icon/components';
import { site } from '~/data/site';
import { metrics } from '~/data/metrics';
import { getLang, t } from '~/i18n';

const lang = getLang(Astro.url.pathname);
const tr = t(lang);

const cta = [
  { href: site.cv.path, label: lang === 'zh' ? '下载简历' : 'Download CV', icon: 'lucide:download', accent: true, download: true },
  { href: site.socials.email, label: tr.hero.ctaEmail, icon: 'lucide:mail', accent: false },
  { href: site.socials.scholar, label: tr.hero.ctaScholar, icon: 'simple-icons:googlescholar', accent: false, external: true },
];

// Prose-translated affiliation roles for the small affiliation row beneath the photo
const affiliationRoles =
  lang === 'zh'
    ? ['高级数据科学家(癌症数据科学)', '兼职讲师(Adjunct Lecturer)']
    : [site.affiliations[0].role, site.affiliations[1].role];
---

<section class="relative overflow-hidden border-b border-border">
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 bg-[radial-gradient(60rem_20rem_at_100%_-10%,rgb(var(--accent)/0.08),transparent),radial-gradient(40rem_20rem_at_0%_110%,rgb(var(--accent-2)/0.07),transparent)]"
  >
  </div>

  <div class="container-page relative grid items-center gap-10 py-20 md:grid-cols-12 md:gap-12 md:py-28">
    <div class="md:col-span-8">
      <div class="section-label">{tr.hero.eyebrow}</div>

      {lang === 'en' ? (
        <h1 class="h-display mt-2 max-w-[20ch] font-semibold">
          Zhaoxiang
          <span class="font-normal italic text-fg/60">(Simon)</span>
          <span class="text-accent">Cai</span>.
        </h1>
      ) : (
        <h1 class="h-display mt-2 max-w-[20ch] font-semibold">
          <span class="text-accent">蔡</span>兆翔
          <span class="ml-1 font-normal italic text-fg/60">(Simon)</span>
        </h1>
      )}

      <p class="mt-6 max-w-prose text-lg text-muted md:text-xl">
        {tr.hero.taglinePart1}
        <a href={site.affiliations[0].url} class="link-underline text-fg" rel="noopener noreferrer" target="_blank">{lang === 'zh' ? 'CMRI' : 'CMRI'}</a>
        {tr.hero.taglineMid}
        <a href={site.affiliations[1].url} class="link-underline text-fg" rel="noopener noreferrer" target="_blank">{lang === 'zh' ? '悉尼大学' : 'University of Sydney'}</a>
        {tr.hero.taglineEnd}
      </p>

      <div class="mt-8 flex flex-wrap items-center gap-3">
        {
          cta.map((c) => (
            <a
              href={c.href}
              class:list={[
                'group inline-flex items-center gap-2 rounded-md px-4 py-2.5 text-sm font-medium transition',
                c.accent
                  ? 'bg-accent text-white hover:bg-accent/90'
                  : 'border border-border bg-surface text-fg hover:border-accent hover:text-accent',
              ]}
              rel={c.external ? 'noopener noreferrer' : undefined}
              target={c.external ? '_blank' : undefined}
              download={c.download ? '' : undefined}
            >
              <Icon name={c.icon} class="h-4 w-4" />
              {c.label}
              {c.external && <Icon name="lucide:arrow-up-right" class="h-3.5 w-3.5 opacity-60" />}
            </a>
          ))
        }
      </div>

      <div class="mt-10 flex flex-wrap items-center gap-x-8 gap-y-4 text-sm text-muted">
        {
          site.affiliations.map((a, i) => (
            <a
              href={a.url}
              class="group flex items-center gap-3 transition hover:text-fg"
              rel="noopener noreferrer"
              target="_blank"
            >
              <img
                src={a.logo}
                alt=""
                loading="lazy"
                class="h-8 w-8 opacity-80 transition group-hover:opacity-100 dark:brightness-0 dark:invert"
              />
              <div class="text-xs leading-tight">
                <div class="font-medium">{lang === 'zh' && i === 1 ? '悉尼大学' : a.nameShort}</div>
                <div class="opacity-70">{affiliationRoles[i]}</div>
              </div>
            </a>
          ))
        }
      </div>
    </div>

    <div class="md:col-span-4">
      <div class="relative mx-auto aspect-square w-full max-w-[300px]">
        <div
          aria-hidden="true"
          class="absolute -inset-2 rounded-full bg-gradient-to-br from-accent/20 via-transparent to-accent-2/20 blur-sm"
        >
        </div>
        <img
          src="/profile.jpg"
          alt={tr.siteName}
          width="600"
          height="600"
          loading="eager"
          decoding="async"
          class="relative aspect-square w-full rounded-full border border-border object-cover shadow-sm"
        />
        <div class="absolute -bottom-3 left-1/2 flex -translate-x-1/2 items-center gap-1.5 whitespace-nowrap rounded-full border border-border bg-surface px-3 py-1 text-[11px] font-medium shadow-sm">
          <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
          <span class="text-muted">{metrics.fellowship.awardedYear} {tr.hero.cinswFellow}</span>
        </div>
      </div>
    </div>
  </div>
</section>
