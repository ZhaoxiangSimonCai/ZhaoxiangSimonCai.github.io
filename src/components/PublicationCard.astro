---
import type { CollectionEntry } from 'astro:content';
import { Icon } from 'astro-icon/components';
import { cleanVenue, doiUrl, authorRole, formatAuthors } from '~/lib/format';

export interface Props {
  pub: CollectionEntry<'publications'>;
  compact?: boolean;
}

const { pub, compact = false } = Astro.props;
const d = pub.data;
const venue = cleanVenue(d.venue);
const href = `/research/${pub.slug}/`;
const role = authorRole(d);
const authorsHtml = formatAuthors(d.authors);
---

<article
  class:list={[
    'group flex flex-col gap-3 rounded-lg border border-border bg-surface p-5 transition hover:border-accent/60 hover:shadow-[0_2px_0_rgb(var(--accent))]',
    compact && 'p-4',
  ]}
>
  <header class="flex items-start justify-between gap-4">
    <div class="flex min-w-0 flex-col">
      <div class="flex flex-wrap items-center gap-2 text-xs text-muted">
        <span class="font-mono uppercase tracking-wide">{d.year}</span>
        <span class="text-border">·</span>
        <span class="italic">{venue}</span>
        {d.fwci !== undefined && (
          <>
            <span class="text-border">·</span>
            <span class="font-mono">FWCI {d.fwci.toFixed(2)}</span>
          </>
        )}
      </div>
      <h3
        class:list={[
          'mt-1.5 font-display font-semibold leading-snug text-fg',
          compact ? 'text-base' : 'text-lg md:text-xl',
        ]}
      >
        <a href={href} class="after:absolute after:inset-0">{d.title}</a>
      </h3>
    </div>

    {role && (
      <span class="chip-accent shrink-0 whitespace-nowrap">{role}</span>
    )}
  </header>

  <p class="text-sm text-muted" set:html={authorsHtml} />

  {!compact && d.abstract && (
    <p class="line-clamp-3 text-sm leading-relaxed text-muted">{d.abstract}</p>
  )}

  <footer class="relative z-10 mt-auto flex flex-wrap items-center gap-2 pt-2">
    {d.doi && (
      <a
        href={doiUrl(d.doi)}
        class="chip hover:border-accent hover:text-accent"
        rel="noopener noreferrer"
        target="_blank"
        aria-label={`DOI ${d.doi}`}
      >
        <Icon name="lucide:link-2" class="h-3 w-3" />
        DOI
      </a>
    )}
    {d.pdf && (
      <a
        href={d.pdf.startsWith('http') ? d.pdf : `/pdfs/${d.pdf}`}
        class="chip hover:border-accent hover:text-accent"
        rel="noopener noreferrer"
        target="_blank"
      >
        <Icon name="lucide:file-text" class="h-3 w-3" />
        PDF
      </a>
    )}
    {d.code && (
      <a
        href={d.code}
        class="chip hover:border-accent hover:text-accent"
        rel="noopener noreferrer"
        target="_blank"
      >
        <Icon name="simple-icons:github" class="h-3 w-3" />
        Code
      </a>
    )}
    {d.tags?.slice(0, 3).map((t) => (
      <span class="chip bg-transparent">{t}</span>
    ))}
  </footer>
</article>
