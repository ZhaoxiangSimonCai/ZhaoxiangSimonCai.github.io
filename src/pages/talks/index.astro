---
import { getCollection } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import Section from '~/components/Section.astro';
import TalkRow from '~/components/TalkRow.astro';
import { sortByDateDesc } from '~/lib/format';
import { t } from '~/i18n';

const tr = t('en');
const talks = sortByDateDesc(await getCollection('talks'));
---

<BaseLayout
  title="Talks"
  description="Conference presentations, invited talks, institutional seminars, and media by Zhaoxiang (Simon) Cai."
>
  <Section label={tr.talks.label} title={tr.talks.title} description={tr.talks.description}>
    <div class="max-w-4xl">
      {talks.map((tk) => <TalkRow talk={tk} />)}
    </div>
  </Section>
</BaseLayout>
