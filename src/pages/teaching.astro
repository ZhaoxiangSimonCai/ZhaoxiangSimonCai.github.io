---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Section from '~/components/Section.astro';
import {
  intro,
  hdrSupervision,
  postdocSupervision,
  thesisExamination,
  informalMentorship,
  professionalTraining,
} from '~/data/teaching';
import type { SuperviseeEntry } from '~/data/teaching';

interface Props {}

const supervisionGroups: { label: string; title: string; items: readonly SuperviseeEntry[] }[] = [
  {
    label: 'HDR co-supervision',
    title: 'Doctoral students',
    items: hdrSupervision,
  },
  {
    label: 'Postdoctoral supervision',
    title: 'Postdoctoral researchers',
    items: postdocSupervision,
  },
  {
    label: 'Thesis examination',
    title: 'External examination',
    items: thesisExamination,
  },
];
---

<BaseLayout
  title="Teaching"
  description="Teaching, HDR supervision, postdoctoral mentoring, thesis examination, and informal mentorship by Zhaoxiang (Simon) Cai — cancer data scientist at CMRI / University of Sydney."
>
  <Section
    label="Teaching & supervision"
    title="Teaching"
    description={intro}
  />

  {
    supervisionGroups.map((group) => (
      <Section label={group.label} title={group.title} bordered>
        <div class="grid max-w-4xl gap-5">
          {group.items.map((s) => (
            <article class="surface-card">
              <div class="flex flex-wrap items-baseline justify-between gap-x-6 gap-y-1">
                <h3 class="font-display text-lg font-semibold text-fg">{s.name}</h3>
                <span class="font-mono text-xs uppercase tracking-wide text-muted">{s.years}</span>
              </div>
              <div class="mt-1 text-sm text-muted">
                {s.role} <span class="text-border">·</span> {s.institution}
              </div>
              {s.project && (
                <p class="mt-3 text-sm leading-relaxed">
                  <span class="font-medium text-fg">Project:</span>{' '}
                  <span class="text-fg/80">{s.project}</span>
                </p>
              )}
              <p class="mt-2 text-sm leading-relaxed text-muted">{s.contribution}</p>
            </article>
          ))}
        </div>
      </Section>
    ))
  }

  <Section
    label="Informal mentorship"
    title="Mentorship at CMRI"
    description={informalMentorship.summary}
    bordered
  >
    <div class="grid max-w-4xl gap-4 md:grid-cols-3">
      {
        informalMentorship.highlights.map((h) => (
          <div class="rounded-lg border border-border bg-surface p-5">
            <h3 class="font-display text-base font-semibold text-fg">{h.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted">{h.detail}</p>
          </div>
        ))
      }
    </div>
  </Section>

  <Section label="Professional training" title="Supervision training" bordered>
    <ul class="max-w-3xl divide-y divide-border">
      {
        professionalTraining.map((t) => (
          <li class="flex flex-wrap items-baseline justify-between gap-x-6 gap-y-1 py-3">
            <div class="flex items-baseline gap-3">
              <span class="font-mono text-xs text-muted">{t.year}</span>
              <span class="text-fg">{t.title}</span>
            </div>
            <span class="text-sm text-muted">{t.institution}</span>
          </li>
        ))
      }
    </ul>
  </Section>
</BaseLayout>
