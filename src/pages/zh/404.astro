---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';
import { t } from '~/i18n';

const tr = t('zh');
---

<BaseLayout title="404" description={tr.notFound.title} noindex>
  <section class="container-page grid min-h-[60vh] place-items-center py-24 text-center">
    <div>
      <div class="font-mono text-xs uppercase tracking-[0.16em] text-muted">404</div>
      <h1 class="mt-4 font-display text-4xl font-semibold md:text-6xl">{tr.notFound.title}</h1>
      <p class="mt-4 text-muted">{tr.notFound.blurb}</p>
      <div class="mt-8 flex flex-wrap justify-center gap-2">
        <a
          href="/zh/"
          class="inline-flex items-center gap-2 rounded-md bg-accent px-4 py-2 text-sm font-medium text-white transition hover:bg-accent/90"
        >
          <Icon name="lucide:home" class="h-4 w-4" /> {tr.common.home}
        </a>
        <a
          href="/zh/research/"
          class="inline-flex items-center gap-2 rounded-md border border-border bg-surface px-4 py-2 text-sm font-medium transition hover:border-accent hover:text-accent"
        >
          {tr.nav.research}
        </a>
        <a
          href="/zh/cv/"
          class="inline-flex items-center gap-2 rounded-md border border-border bg-surface px-4 py-2 text-sm font-medium transition hover:border-accent hover:text-accent"
        >
          {tr.nav.cv}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
