---
import { getCollection } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import Section from '~/components/Section.astro';
import ProjectCard from '~/components/ProjectCard.astro';
import { sortByDateDesc } from '~/lib/format';
import { t } from '~/i18n';

const tr = t('zh');
const projects = sortByDateDesc(await getCollection('projects'));
---

<BaseLayout title={tr.projects.title} description="蔡兆祥（Simon）的研究项目 —— 代码、数据集与研究产出。">
  <Section label={tr.projects.label} title={tr.projects.title} description={tr.projects.description}>
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {projects.map((p) => <ProjectCard project={p} />)}
    </div>
  </Section>
</BaseLayout>
