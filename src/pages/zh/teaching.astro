---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Section from '~/components/Section.astro';
import { t, teachingZh } from '~/i18n';

const tr = t('zh');

const supervisionGroups = [
  { label: tr.teaching.groups.hdr.label, title: tr.teaching.groups.hdr.title, items: teachingZh.hdr },
  { label: tr.teaching.groups.postdoc.label, title: tr.teaching.groups.postdoc.title, items: teachingZh.postdoc },
  { label: tr.teaching.groups.thesis.label, title: tr.teaching.groups.thesis.title, items: teachingZh.thesis },
];
---

<BaseLayout
  title={tr.teaching.title}
  description="蔡兆祥（Simon）的教学、博士生联合指导、博士后培养、论文答辩评审与非正式指导工作。"
>
  <Section label={tr.teaching.label} title={tr.teaching.title} description={teachingZh.intro} />

  {
    supervisionGroups.map((group) => (
      <Section label={group.label} title={group.title} bordered>
        <div class="grid max-w-4xl gap-5">
          {group.items.map((s) => (
            <article class="surface-card">
              <div class="flex flex-wrap items-baseline justify-between gap-x-6 gap-y-1">
                <h3 class="font-display text-lg font-semibold text-fg">{s.name}</h3>
                <span class="font-mono text-xs uppercase tracking-wide text-muted">{s.years}</span>
              </div>
              <div class="mt-1 text-sm text-muted">
                {s.role} <span class="text-border">·</span> {s.institution}
              </div>
              {s.project && (
                <p class="mt-3 text-sm leading-relaxed">
                  <span class="font-medium text-fg">{tr.teaching.project}</span>{' '}
                  <span class="text-fg/80">{s.project}</span>
                </p>
              )}
              <p class="mt-2 text-sm leading-relaxed text-muted">{s.contribution}</p>
            </article>
          ))}
        </div>
      </Section>
    ))
  }

  <Section
    label={tr.teaching.mentorshipLabel}
    title={tr.teaching.mentorshipTitle}
    description={teachingZh.mentorshipSummary}
    bordered
  >
    <div class="grid max-w-4xl gap-4 md:grid-cols-3">
      {
        teachingZh.mentorshipHighlights.map((h) => (
          <div class="rounded-lg border border-border bg-surface p-5">
            <h3 class="font-display text-base font-semibold text-fg">{h.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted">{h.detail}</p>
          </div>
        ))
      }
    </div>
  </Section>

  <Section label={tr.teaching.trainingLabel} title={tr.teaching.trainingTitle} bordered>
    <ul class="max-w-3xl divide-y divide-border">
      {
        teachingZh.professionalTraining.map((t) => (
          <li class="flex flex-wrap items-baseline justify-between gap-x-6 gap-y-1 py-3">
            <div class="flex items-baseline gap-3">
              <span class="font-mono text-xs text-muted">{t.year}</span>
              <span class="text-fg">{t.title}</span>
            </div>
            <span class="text-sm text-muted">{t.institution}</span>
          </li>
        ))
      }
    </ul>
  </Section>
</BaseLayout>
