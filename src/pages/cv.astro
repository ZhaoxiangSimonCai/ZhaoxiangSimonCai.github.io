---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Section from '~/components/Section.astro';
import { Icon } from 'astro-icon/components';
import { site } from '~/data/site';
---

<BaseLayout
  title="CV"
  description="Curriculum Vitae for Zhaoxiang (Simon) Cai — PhD Cancer Data Science, Senior Data Scientist at CMRI."
>
  <Section
    label="Curriculum Vitae"
    title="Full CV"
    description={`Last updated ${site.cv.lastUpdated}. Download the PDF or view it inline below.`}
  >
    <div class="mb-6 flex flex-wrap items-center gap-3">
      <a
        href={site.cv.path}
        download
        class="inline-flex items-center gap-2 rounded-md bg-accent px-4 py-2 text-sm font-medium text-white transition hover:bg-accent/90"
      >
        <Icon name="lucide:download" class="h-4 w-4" /> Download PDF
      </a>
      <a
        href={site.cv.path}
        rel="noopener noreferrer"
        target="_blank"
        class="inline-flex items-center gap-2 rounded-md border border-border bg-surface px-4 py-2 text-sm font-medium transition hover:border-accent hover:text-accent"
      >
        <Icon name="lucide:external-link" class="h-4 w-4" /> Open in new tab
      </a>
    </div>

    <div class="aspect-[8.5/11] w-full overflow-hidden rounded-lg border border-border bg-surface-2">
      <iframe
        src={`${site.cv.path}#view=FitH`}
        title="Curriculum Vitae"
        class="h-full w-full"
        loading="lazy"
      ></iframe>
    </div>

    <p class="mt-6 text-sm text-muted">
      If the PDF does not render (some browsers block embedded PDFs),
      <a href={site.cv.path} class="link-underline text-accent-2" download>download it directly</a>.
    </p>
  </Section>
</BaseLayout>
